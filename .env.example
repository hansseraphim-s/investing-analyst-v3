# =========================================================================
# investing-analyst-v3 environment configuration
# Copy this file to .env and fill in your secrets. NEVER commit .env.
# =========================================================================

# ---- Trading mode -------------------------------------------------------
# PAPER (default) or LIVE. LIVE requires walk-forward validation gates to
# be passed AND an explicit human decision. See README go-live checklist.
TRADING_MODE=PAPER

# ---- Alpaca (broker + market data + options chains) --------------------
# Paper account: https://app.alpaca.markets/paper/dashboard/overview
# Live account:  https://app.alpaca.markets/dashboard/overview
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Paper endpoint: https://paper-api.alpaca.markets
# Live endpoint:  https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# ---- Finnhub (earnings calendar, news, sentiment) ----------------------
# Free tier: 60 calls/min. Get a key at https://finnhub.io/dashboard
FINNHUB_API_KEY=

# ---- Anthropic (advisor commentary only, NOT in decision path) ---------
# Get key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---- Neon Postgres (cloud journal store powering the dashboard) -------
# Free tier 0.5GB. Create at https://console.neon.tech
# Use the pooled connection string.
NEON_DATABASE_URL=

# ---- Dashboard (Next.js on Vercel) -------------------------------------
DASHBOARD_URL=

# Clerk auth (free tier up to 10k MAU)
# Create app at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---- Risk caps (consumed at startup) -----------------------------------
# These are HARD caps. Strategy-level sizing must be tighter.
RISK_MAX_DAILY_LOSS_PCT=0.03
RISK_MAX_POSITION_PCT=0.20
RISK_MAX_ORDER_VALUE=10000
RISK_MAX_TRADES_PER_DAY=20
RISK_MIN_CASH_RESERVE_PCT=0.10
RISK_PORTFOLIO_VOL_TARGET=0.15
RISK_MAX_PORTFOLIO_DELTA=1.5
RISK_MAX_PORTFOLIO_VEGA=500
RISK_MAX_DRAWDOWN_KILL_SWITCH_PCT=0.15
