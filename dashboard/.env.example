# Dashboard env (subset of the root .env). Copy to .env.local for local dev,
# or set in Vercel project settings for deploys.

# Neon Postgres (same DSN as the agent uses)
NEON_DATABASE_URL=

# Clerk auth — create app at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Display only — the mode badge in the header.
NEXT_PUBLIC_TRADING_MODE=PAPER
